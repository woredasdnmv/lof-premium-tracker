# Flask 配置
HOST=0.0.0.0
PORT=5000
DEBUG=false

# 数据库配置（二选一）
# 方式1：使用 DATABASE_URL（Railway 等平台自动注入，优先级最高）
# DATABASE_URL=postgresql://user:password@host:port/dbname

# 方式2：使用独立的环境变量（本地开发推荐）
DB_HOST=localhost
DB_PORT=5432
DB_NAME=lof_funds
DB_USER=postgres
DB_PASSWORD=your_password

# 连接池配置
DB_POOL_MIN=2
DB_POOL_MAX=10

# 应用配置
REFRESH_INTERVAL=300
LOG_LEVEL=INFO
REQUEST_TIMEOUT=30

# 数据源配置（可选）
# TuShare Token (用于获取历史 K 线备源数据，需去官网注册获取)
# TUSHARE_TOKEN=
