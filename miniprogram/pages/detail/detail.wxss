/* 详情页样式 */

.fund-header {
  background: linear-gradient(135deg, #1890ff, #096dd9);
  border-radius: 16rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 20rpx;
  color: #fff;
}

.fund-name {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.fund-code {
  display: inline-flex;
  align-items: center;
  font-size: 28rpx;
  opacity: 0.9;
}

.copy-hint {
  margin-left: 12rpx;
  font-size: 22rpx;
  background: rgba(255,255,255,0.2);
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.card-title {
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.price-row {
  display: flex;
  align-items: baseline;
  margin-bottom: 24rpx;
}

.big-price {
  font-size: 56rpx;
  font-weight: bold;
  color: #333;
  margin-right: 16rpx;
}

.change {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.change.up {
  color: #e74c3c;
}

.change.down {
  color: #27ae60;
}

.change-amount {
  font-size: 24rpx;
  color: #666;
}

.info-grid {
  display: flex;
  justify-content: space-between;
}

.info-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.info-item .label {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.info-item text:last-child {
  font-size: 28rpx;
  color: #333;
}

.nav-row {
  display: flex;
  gap: 20rpx;
}

.nav-block, .premium-block {
  flex: 1;
  background: #fafafa;
  border-radius: 12rpx;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.nav-block .label, .premium-block .label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.nav-block .value {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.nav-block .sub {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.nav-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-top: 4rpx;
}

.nav-tag.formal {
  background: #e6f7ff;
  color: #1890ff;
}

.nav-tag.est {
  background: #fff7e6;
  color: #fa8c16;
}

.premium-block .premium-value {
  font-size: 44rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.premium-positive {
  color: #e74c3c !important;
}

.premium-negative {
  color: #27ae60 !important;
}

.premium-zero {
  color: #333 !important;
}

.premium-block .premium-label {
  font-size: 22rpx;
  color: #999;
}

.purchase-limit-row {
  display: flex; justify-content: space-between; align-items: center;
  padding-top: 20rpx; margin-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}
.purchase-limit-row .label { font-size: 24rpx; color: #999; }
.purchase-limit-row .value { font-size: 28rpx; color: #333; font-weight: 500; }

/* Chart */
.chart-card { padding-bottom: 20rpx; }
.chart-range { display: flex; gap: 12rpx; justify-content: center; margin-bottom: 16rpx; }
.range-btn { padding: 8rpx 32rpx; border: 1rpx solid #d9d9d9; border-radius: 32rpx; font-size: 24rpx; color: #666; background: #fff; }
.range-btn.active { background: #1890ff; color: #fff; border-color: #1890ff; }
.chart-legend { display: flex; gap: 30rpx; justify-content: center; margin-bottom: 16rpx; font-size: 22rpx; color: #666; }
.legend-item { display: flex; align-items: center; gap: 8rpx; }
.legend-dot { width: 16rpx; height: 16rpx; border-radius: 50%; }
.legend-dot--price { background: #ff7a45; }
.legend-dot--nav { background: #40a9ff; }
.detail-chart { width: 100%; }

.tip-card {
  background: #fffbe6;
  border: 1rpx solid #ffe58f;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 30rpx;
  display: flex;
  flex-direction: column;
  font-size: 22rpx;
  color: #8c6d1f;
  line-height: 1.8;
}

.back-btn-wrap {
  padding: 20rpx 0 60rpx;
}

.back-btn {
  background: #1890ff !important;
  color: #fff !important;
  border-radius: 40rpx !important;
  font-size: 30rpx !important;
}

/* Loading */
.global-loading {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(255,255,255,0.85);
  z-index: 999;
  font-size: 28rpx;
  color: #1890ff;
}

.loading-spinner {
  width: 60rpx; height: 60rpx;
  border: 4rpx solid #e0e0e0;
  border-top-color: #1890ff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin { to { transform: rotate(360deg); } }

/* Error */
.error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}

.error-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.error-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 30rpx;
}

.retry-btn {
  background: #1890ff !important;
  color: #fff !important;
}
