/* 首页样式 */

/* 统计卡片 */
.stats-card {
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  color: #fff;
}

.stats-row {
  display: flex;
  justify-content: space-around;
  margin-bottom: 20rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 22rpx;
  opacity: 0.85;
}

.stats-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(255,255,255,0.2);
}

.update-time {
  font-size: 22rpx;
  opacity: 0.75;
}

.refresh-btn {
  background: rgba(255,255,255,0.2) !important;
  color: #fff !important;
  border: 1rpx solid rgba(255,255,255,0.4) !important;
  font-size: 22rpx !important;
  padding: 4rpx 16rpx !important;
  border-radius: 20rpx !important;
  line-height: 1.5 !important;
}

/* 搜索栏 */
.search-bar {
  background: #fff;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.search-focused {
  box-shadow: 0 2rpx 16rpx rgba(24,144,255,0.2);
}

.search-input-wrap {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 32rpx;
  padding: 12rpx 20rpx;
}

.search-icon {
  margin-right: 12rpx;
  font-size: 28rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  height: 40rpx;
}

.clear-icon {
  font-size: 28rpx;
  color: #999;
  padding: 0 8rpx;
}

/* 排序栏 */
.sort-bar {
  display: flex;
  background: #fff;
  border-radius: 12rpx;
  padding: 16rpx 0;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.sort-item {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  color: #666;
  padding: 8rpx 0;
  border-right: 1rpx solid #eee;
  display: flex;
  align-items: center;
  justify-content: center;
}

.sort-item:last-child {
  border-right: none;
}

.sort-active {
  color: #1890ff;
  font-weight: bold;
}

.sort-arrow {
  margin-left: 4rpx;
  font-size: 20rpx;
}

/* 基金列表 */
.fund-list {
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.fund-header {
  display: flex;
  align-items: center;
  padding: 20rpx 16rpx;
  background: #fafafa;
  font-size: 22rpx;
  color: #999;
  border-bottom: 1rpx solid #eee;
}

.fund-row {
  display: flex;
  align-items: center;
  padding: 24rpx 16rpx;
  border-bottom: 1rpx solid #f5f5f5;
  font-size: 24rpx;
}

.fund-row:active {
  background: #f9f9f9;
}

/* 列宽度 */
.col-code {
  width: 120rpx;
  font-size: 24rpx;
}

.col-name {
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 24rpx;
}

.col-price {
  width: 100rpx;
  text-align: right;
  font-size: 24rpx;
}

.col-nav {
  width: 100rpx;
  text-align: right;
  font-size: 24rpx;
}

.col-premium {
  width: 120rpx;
  text-align: right;
  font-weight: bold;
  font-size: 24rpx;
}

.col-amount {
  width: 110rpx;
  text-align: right;
  font-size: 22rpx;
  color: #666;
}

/* 溢价率颜色 */
.premium-positive {
  color: #e74c3c;
}

.premium-negative {
  color: #27ae60;
}

.premium-zero {
  color: #333;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* 底部提示 */
.footer-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx 0;
  font-size: 22rpx;
  color: #999;
}

/* 全局 loading */
.global-loading {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(255,255,255,0.85);
  z-index: 999;
  font-size: 28rpx;
  color: #1890ff;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #e0e0e0;
  border-top-color: #1890ff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}
