<!--
  LOF基金监控 - 首页
  功能：统计卡片 + 搜索 + 排序 + 基金列表 + 下拉刷新 + 自动轮询
-->
<view class="container">

  <!-- 统计卡片 -->
  <view class="stats-card">
    <view class="stats-row">
      <view class="stat-item">
        <text class="stat-value">{{fundCount}}</text>
        <text class="stat-label">LOF基金总数</text>
      </view>
      <view class="stat-item">
        <text class="stat-value text-danger">{{maxPremium}}</text>
        <text class="stat-label">最高溢价率</text>
      </view>
      <view class="stat-item">
        <text class="stat-value text-success">{{minDiscount}}</text>
        <text class="stat-label">最低折价率</text>
      </view>
    </view>
    <view class="stats-footer">
      <text class="update-time">数据更新: {{lastFetch}}</text>
      <button class="refresh-btn" size="mini" bindtap="handleRefresh" loading="{{refreshing}}">
        🔄 刷新数据
      </button>
    </view>
  </view>

  <!-- 搜索栏 -->
  <view class="search-bar {{searchFocused ? 'search-focused' : ''}}">
    <view class="search-input-wrap">
      <text class="search-icon">🔍</text>
      <input
        class="search-input"
        placeholder="搜索基金代码或名称..."
        value="{{keyword}}"
        bindinput="onSearchInput"
        bindfocus="onSearchFocus"
        bindblur="onSearchBlur"
        confirm-type="search"
      />
      <text wx:if="{{keyword}}" class="clear-icon" bindtap="onClearSearch">✕</text>
    </view>
  </view>

  <!-- 排序栏 -->
  <view class="sort-bar">
    <view
      wx:for="{{sortOptions}}"
      wx:key="field"
      class="sort-item {{activeSortIndex === index ? 'sort-active' : ''}}"
      data-index="{{index}}"
      bindtap="onSortTap"
    >
      <text>{{item.label}}</text>
      <text wx:if="{{activeSortIndex === index}}" class="sort-arrow">
        {{sortOrder === 'desc' ? '↓' : '↑'}}
      </text>
    </view>
  </view>

  <!-- 基金列表 -->
  <view class="fund-list">
    <!-- 列表头 -->
    <view class="fund-header">
      <text class="col-code">代码</text>
      <text class="col-name">名称</text>
      <text class="col-price">现价</text>
      <text class="col-nav">净值</text>
      <text class="col-premium">溢价率</text>
      <text class="col-amount">成交额</text>
    </view>

    <!-- 空状态 -->
    <view wx:if="{{!loading && fundList.length === 0}}" class="empty-state">
      <text class="empty-icon">📭</text>
      <text class="empty-text">{{keyword ? '未找到匹配的基金' : '暂无数据'}}</text>
    </view>

    <!-- 数据行 -->
    <view
      wx:for="{{fundList}}"
      wx:key="code"
      class="fund-row"
      data-code="{{item.code}}"
      bindtap="goDetail"
    >
      <text class="col-code text-primary">{{item.code}}</text>
      <text class="col-name">{{item.name}}</text>
      <text class="col-price">{{formatPrice(item.price)}}</text>
      <text class="col-nav">{{formatPrice(item.nav)}}</text>
      <text class="col-premium {{getPremiumClass(item.premium_rate)}}">
        {{formatPremiumRate(item.premium_rate)}}
      </text>
      <text class="col-amount">{{formatAmount(item.amount_w)}}</text>
    </view>
  </view>

  <!-- 底部提示 -->
  <view class="footer-tip">
    <text>💡 溢价率 = (现价 - 净值) / 净值 × 100%</text>
    <text>溢价 > 0 红色 | 折价 < 0 绿色 | 仅供参考</text>
  </view>

  <!-- 全局 loading -->
  <view wx:if="{{loading}}" class="global-loading">
    <view class="loading-spinner"></view>
    <text>数据加载中...</text>
  </view>

</view>
